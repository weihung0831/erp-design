---
import Base from '../layouts/Base.astro';
---
<Base title="找不到頁面 — ERP Design Systems">
  <div class="not-found">
    <h1>404</h1>
    <p>找不到頁面</p>
    <a href={import.meta.env.BASE_URL}>← 返回首頁</a>
  </div>
</Base>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    text-align: center;
    gap: 8px;
  }

  .not-found h1 {
    font-size: 64px;
    font-weight: 600;
    letter-spacing: -2.4px;
    color: var(--text-muted);
  }

  .not-found p {
    font-size: 18px;
    color: var(--text-secondary);
    margin-bottom: 16px;
  }

  .not-found a {
    font-size: 14px;
    color: var(--text-tertiary);
  }

  .not-found a:hover {
    color: var(--text-primary);
  }
</style>
