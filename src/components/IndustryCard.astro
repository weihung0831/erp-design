---
interface Props {
  slug: string;
  nameZh: string;
  nameEn: string;
  accent: string;
  description: string;
}

const { slug, nameZh, nameEn, accent, description } = Astro.props;
const href = `${import.meta.env.BASE_URL}designs/${slug}`;
---
<a href={href} class="card" style={`--accent: ${accent};`}>
  <div class="card-header">
    <span class="card-dot" />
    <span class="card-name-zh">{nameZh}</span>
  </div>
  <div class="card-name-en">{nameEn}</div>
  <p class="card-desc">{description}</p>
</a>

<style>
  .card {
    display: block;
    padding: 24px;
    border-radius: 8px;
    border-left: 4px solid var(--accent);
    box-shadow: var(--shadow-card);
    background: var(--bg);
    color: var(--text-primary);
    text-decoration: none;
    transition: box-shadow 0.15s ease, transform 0.15s ease;
  }

  .card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-card), 0 0 20px color-mix(in srgb, var(--accent) 25%, transparent);
    transform: translateY(-1px);
  }

  .card:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .card-dot {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .card-name-zh {
    font-size: 18px;
    font-weight: 600;
    letter-spacing: -0.32px;
  }

  .card-name-en {
    font-size: 14px;
    font-weight: 400;
    color: var(--text-secondary);
    margin-bottom: 12px;
  }

  .card-desc {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-tertiary);
  }
</style>
